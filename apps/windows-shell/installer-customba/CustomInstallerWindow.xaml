<Window x:Class="LandslideDesk.CustomBA.CustomInstallerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="山体滑坡监测桌面端 安装程序"
        Icon="LandslideDesk.ico"
        Height="560"
        Width="920"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#07131D" />
            <Setter Property="Background" Value="#5BC3E0" />
            <Setter Property="BorderBrush" Value="#5BC3E0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="Bold" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#7F8E99" />
                    <Setter Property="Background" Value="#22323D" />
                    <Setter Property="BorderBrush" Value="#31424F" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F4F7FA" />
            <Setter Property="Background" Value="#1B2D3E" />
            <Setter Property="BorderBrush" Value="#35556F" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#7F8E99" />
                    <Setter Property="Background" Value="#16222B" />
                    <Setter Property="BorderBrush" Value="#2A3945" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent" MouseLeftButtonDown="RootSurface_OnMouseLeftButtonDown">
        <Border Margin="8" Background="#07131D" CornerRadius="36" BorderBrush="#244157" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#AA02070C" Opacity="0.9" />
            </Border.Effect>
            <Border Margin="4" Background="#0B1723" CornerRadius="32" BorderBrush="#1D3346" BorderThickness="1">
                <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="58" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="18,14,18,0" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="46" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="14" Background="#132A3C">
                        <Image Source="LandslideDesk.ico" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0">
                        <TextBlock Text="山体滑坡监测桌面端" FontSize="15" FontWeight="SemiBold" Foreground="#EAF1F6" />
                        <TextBlock Text="安装程序" FontSize="12" Foreground="#8FB2C7" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Width="38"
                        Height="38"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#112130"
                        Foreground="#EAF1F6"
                        BorderBrush="#29465D"
                        Content="×"
                        FontSize="18"
                        Click="CloseButton_OnClick" />
            </Grid>

            <Border Grid.Row="1" Background="#10263A" CornerRadius="0,0,0,32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Margin="22" CornerRadius="24" Background="#16364F">
                        <Grid>
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#17344C" Offset="0" />
                                    <GradientStop Color="#0A1521" Offset="1" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Canvas>
                                <Ellipse Width="180" Height="180" Canvas.Left="18" Canvas.Top="18" Fill="#203D57" />
                                <Ellipse Width="22" Height="22" Canvas.Left="222" Canvas.Top="62" Fill="#C5A05B" />
                                <Path Stroke="#4FA6D7" StrokeThickness="3" Data="M 12 250 C 70 200 124 188 190 194 C 246 198 278 212 322 246" />
                                <Path Stroke="#315E82" StrokeThickness="2" Data="M 12 276 C 84 228 154 218 228 226 C 276 232 314 246 352 274" />
                                <Path Stroke="#2A4B67" StrokeThickness="2" Data="M 0 326 C 66 294 136 286 210 294 C 276 302 328 324 380 356" />
                            </Canvas>
                            <StackPanel Margin="28,34,28,28" VerticalAlignment="Top">
                                <TextBlock Text="LANDSLIDE DESK" FontSize="14" FontWeight="Bold" Foreground="#D2B163" />
                                <TextBlock Margin="0,18,0,0" Text="山体滑坡监测桌面端" FontSize="34" FontWeight="Bold" Foreground="#F3F7FA" TextWrapping="Wrap" />
                                <TextBlock Margin="0,16,0,0" Text="用于现场安装与部署的桌面端安装程序。" FontSize="16" Foreground="#C8D6E2" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="28,0,28,28">
                        <TextBlock Text="面向 Windows x64 设备" FontSize="15" FontWeight="SemiBold" Foreground="#F3F7FA" />
                        <TextBlock Margin="0,10,0,0" Text="安装完成后可从开始菜单直接启动桌面端。" FontSize="13" Foreground="#B9C9D6" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1" Margin="30,26,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="安装程序" FontSize="34" FontWeight="Bold" Foreground="#F4F7FA" />
                <TextBlock Grid.Row="1" Margin="0,14,0,0" Text="为当前用户安装山体滑坡监测桌面端。你可以调整安装目录，并在安装完成后直接启动应用。" FontSize="15" Foreground="#BFD0DD" TextWrapping="Wrap" />

                <StackPanel Grid.Row="2" Margin="0,34,0,0">
                    <TextBlock Text="安装目录" FontSize="14" FontWeight="SemiBold" Foreground="#E9EEF2" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InstallFolderTextBox"
                                 Grid.Column="0"
                                 Height="42"
                                 Padding="14,0"
                                 VerticalContentAlignment="Center"
                                 Background="#112130"
                                 Foreground="#F2F6F8"
                                 BorderBrush="#2F4E67"
                                 BorderThickness="1" />
                        <Button x:Name="BrowseButton"
                                Grid.Column="2"
                                Height="42"
                                Background="#162A3D"
                                Foreground="#F4F7FA"
                                BorderBrush="#35556F"
                                Content="浏览..."
                                Click="BrowseButton_OnClick" />
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,28,0,0">
                    <TextBlock Text="安装状态" FontSize="14" FontWeight="SemiBold" Foreground="#E9EEF2" />
                    <ProgressBar x:Name="OverallProgressBar"
                                 Margin="0,12,0,0"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Foreground="#5BC3E0"
                                 Background="#1B2D3E" />
                    <TextBlock x:Name="StatusText" Margin="0,12,0,0" Text="等待检测..." FontSize="14" Foreground="#D6E2EA" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Row="4" Margin="0,28,0,0" Background="#0E1C29" CornerRadius="22" Padding="22">
                    <StackPanel>
                        <TextBlock Text="安装说明" FontSize="14" FontWeight="SemiBold" Foreground="#D2B163" />
                        <TextBlock Margin="0,12,0,0" Text="1. 选择安装目录" FontSize="14" Foreground="#F2F6F8" />
                        <TextBlock Margin="0,8,0,0" Text="2. 点击安装开始写入桌面端文件" FontSize="14" Foreground="#F2F6F8" />
                        <TextBlock Margin="0,8,0,0" Text="3. 安装完成后可直接启动应用或关闭安装程序" FontSize="14" Foreground="#F2F6F8" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="5" Margin="0,28,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="InstallButton"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Width="120"
                            Height="40"
                            Margin="0,0,12,0"
                            Content="安装"
                            Click="InstallButton_OnClick" />
                    <Button x:Name="UninstallButton"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Width="120"
                            Height="40"
                            Margin="0,0,12,0"
                            Content="卸载"
                            Click="UninstallButton_OnClick" />
                    <Button x:Name="FinishButton"
                            Width="120"
                            Height="40"
                            Background="#0F1C28"
                            Foreground="#D3E0E8"
                            BorderBrush="#2D4559"
                            Content="完成"
                            Click="CloseButton_OnClick" />
                </StackPanel>
                </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
