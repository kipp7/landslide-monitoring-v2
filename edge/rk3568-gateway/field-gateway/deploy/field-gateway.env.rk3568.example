SERVICE_NAME=field-gateway
SERIAL_DEVICE=/dev/ttyS3
SERIAL_BAUD_RATE=115200
FIELD_LINK_MODE=cobs-crc-v1

MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_TELEMETRY_PREFIX=telemetry/
MQTT_TOPIC_COMMAND_PREFIX=cmd/
MQTT_TOPIC_ACK_PREFIX=cmd_ack/
SOUTHBOUND_NODES_JSON=[{"fieldNodeId":"A","deviceId":"00000000-0000-0000-0000-000000000001","installLabel":"FIELD-NODE-A","southboundPort":"/dev/ttyS3","enabled":true},{"fieldNodeId":"B","deviceId":"00000000-0000-0000-0000-000000000002","installLabel":"FIELD-NODE-B","southboundPort":"/dev/ttyS3","enabled":true},{"fieldNodeId":"C","deviceId":"00000000-0000-0000-0000-000000000003","installLabel":"FIELD-NODE-C","southboundPort":"/dev/ttyS3","enabled":true}]

SPOOL_ROOT_DIR=/var/lib/lsmv2/field-gateway/spool
HEALTH_FILE_PATH=/var/lib/lsmv2/field-gateway/health/runtime-health.json

MQTT_PUBLISH_TIMEOUT_MS=8000
COMMAND_ACK_QUIET_WINDOW_MS=10000
COMMAND_PREWRITE_QUIET_MS=400
COMMAND_PREWRITE_MAX_WAIT_MS=4000
COMMAND_SERIAL_CHUNK_BYTES=32
COMMAND_SERIAL_CHUNK_DELAY_MS=30
SOUTHBOUND_POLLING_ENABLED=true
SOUTHBOUND_POLLING_MODE=compact-broadcast-v1
SOUTHBOUND_POLLING_COMMAND_TYPE=poll_latest_telemetry
SOUTHBOUND_POLLING_INTERVAL_MS=1000
SOUTHBOUND_POLLING_SESSION_TIMEOUT_MS=1500
SOUTHBOUND_POLLING_PREWRITE_QUIET_MS=100
SOUTHBOUND_POLLING_PREWRITE_MAX_WAIT_MS=250
SOUTHBOUND_POLLING_COMMAND_CHUNK_BYTES=64
SOUTHBOUND_POLLING_COMMAND_CHUNK_DELAY_MS=10
SOUTHBOUND_POLLING_SUPPRESS_ACK_PUBLISH=true
REPLAY_INTERVAL_MS=5000
HEALTH_EMIT_INTERVAL_MS=5000
NODE_DEGRADED_AFTER_MS=15000
NODE_OFFLINE_AFTER_MS=30000
PORT_DEGRADED_AFTER_MS=15000
PORT_OFFLINE_AFTER_MS=30000
MAX_MESSAGE_BYTES=262144
MAX_PENDING_RECORDS=10000
SPOOL_RETENTION_PUBLISHED=200
SPOOL_RETENTION_REJECTED=200
