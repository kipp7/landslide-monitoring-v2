{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/alarm-reported-state.v1.schema.json",
  "title": "AlarmReportedState (MQTT) v1",
  "description": "通晓告警终端对最后一次已应用期望状态的保留回报。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "device_id",
    "applied_revision",
    "reported_ts",
    "state",
    "severity",
    "outputs",
    "firmware_version"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "device_id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "applied_revision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "reported_ts": { "type": "string", "format": "date-time" },
    "state": { "type": "string", "enum": ["idle", "active", "silenced", "error"] },
    "severity": { "type": "string", "enum": ["normal", "low", "medium", "high", "critical"] },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["buzzer", "motor", "rgb", "display", "voice_phrase_id"],
      "properties": {
        "buzzer": { "type": "boolean" },
        "motor": { "type": "boolean" },
        "rgb": { "type": "string", "enum": ["off", "red_flash", "red_fast_flash", "amber_solid"] },
        "display": { "type": "string", "enum": ["standby", "risk", "silenced", "all_clear", "self_test"] },
        "voice_phrase_id": {
          "type": ["string", "null"],
          "enum": [null, "PREPARE_01", "EVACUATE_01", "EVACUATE_REPEAT_01", "ALL_CLEAR_01", "SELF_TEST_01"]
        }
      }
    },
    "firmware_version": { "type": "string", "minLength": 1, "maxLength": 32 },
    "rssi_dbm": { "type": ["integer", "null"], "minimum": -127, "maximum": 0 },
    "last_error": { "type": ["string", "null"], "maxLength": 200 }
  }
}
