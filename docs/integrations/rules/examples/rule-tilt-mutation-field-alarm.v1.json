{
  "dslVersion": 1,
  "name": "旧相邻点倾角突变规则（已停用，保留用于兼容审计）",
  "scope": {
    "type": "global"
  },
  "enabled": false,
  "severity": "high",
  "cooldown": { "minutes": 0 },
  "timeField": "received",
  "missing": { "policy": "ignore" },
  "when": {
    "op": "OR",
    "items": [
      {
        "metric": {
          "sensorKey": "tilt_x_deg",
          "agg": "delta",
          "window": { "type": "points", "points": 2 }
        },
        "operator": ">=",
        "value": 3
      },
      {
        "metric": {
          "sensorKey": "tilt_x_deg",
          "agg": "delta",
          "window": { "type": "points", "points": 2 }
        },
        "operator": "<=",
        "value": -3
      },
      {
        "metric": {
          "sensorKey": "tilt_y_deg",
          "agg": "delta",
          "window": { "type": "points", "points": 2 }
        },
        "operator": ">=",
        "value": 3
      },
      {
        "metric": {
          "sensorKey": "tilt_y_deg",
          "agg": "delta",
          "window": { "type": "points", "points": 2 }
        },
        "operator": "<=",
        "value": -3
      },
      {
        "metric": {
          "sensorKey": "tilt_z_deg",
          "agg": "delta",
          "window": { "type": "points", "points": 2 }
        },
        "operator": ">=",
        "value": 3
      },
      {
        "metric": {
          "sensorKey": "tilt_z_deg",
          "agg": "delta",
          "window": { "type": "points", "points": 2 }
        },
        "operator": "<=",
        "value": -3
      }
    ]
  },
  "actions": [
    {
      "type": "emit_alert",
      "titleTemplate": "旧相邻点倾角规则已停用",
      "messageTemplate": "请使用 field_alarm.competition_tilt_profile.v1 相对基线状态机；本规则不参与告警计算。"
    }
  ]
}
