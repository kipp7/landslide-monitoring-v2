          <mxGeometry x="1020" y="700" width="180" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="r1" value="R1&#xa;4.7k&#xa;I2C_SDA 上拉到 3V3_SYS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="760" y="500" width="150" height="70" as="geometry"/>
