        </mxCell>

        <mxCell id="jpwr" value="J_PWR 电源输入&#xa;1  5V_SYS&#xa;2  3V3_SYS&#xa;3  GND&#xa;&#xa;来自外部 DC 电源模块输出" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="180" height="150" as="geometry"/>
