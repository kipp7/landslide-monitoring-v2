          <mxGeometry x="290" y="320" width="140" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="prk" value="P_RK2206 开发板连接区&#xa;这里只表示逻辑连接&#xa;开发板通过 Type-C 独立供电&#xa;&#xa;1  GND&#xa;2  PB2&#xa;3  PB3&#xa;4  PB4&#xa;5  PB5&#xa;6  PB6&#xa;7  PB7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16;" vertex="1" parent="1">
