# 基础设施环境变量示例（单机 Compose）
# 复制为 `.env` 并按需修改；敏感信息不要提交到仓库。

TZ=Asia/Shanghai

# 数据目录（强烈建议外置，便于备份/迁移）
# 说明：路径相对于 `infra/compose/docker-compose.yml` 所在目录解析。
DATA_DIR=../../data

# ClickHouse 数据目录（可选）
# - 默认：使用 Docker named volume（Windows 下更稳定，避免 bind-mount 导致 INSERT/rename 权限问题）
# - 如需落盘到 DATA_DIR：取消注释并按需调整
# CH_DATA_DIR=${DATA_DIR}/clickhouse

# PostgreSQL（元数据/规则/告警/权限）
PG_USER=landslide
PG_PASSWORD=change-me
PG_DATABASE=landslide_monitor
PG_HOST=localhost
PG_PORT=5432
PG_URL=postgresql://${PG_USER}:${PG_PASSWORD}@${PG_HOST}:${PG_PORT}/${PG_DATABASE}

# Redis（缓存/去重/限流计数）
REDIS_PASSWORD=change-me
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# ClickHouse（遥测时序）
CH_DATABASE=landslide
CH_USER=landslide
CH_PASSWORD=change-me
CH_HOST=localhost
CH_HTTP_PORT=8123
CH_NATIVE_PORT=9000
CH_HTTP_URL=http://${CH_HOST}:${CH_HTTP_PORT}

# EMQX（MQTT Broker）
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_URL=mqtt://${MQTT_HOST}:${MQTT_PORT}
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=change-me
# EMQX HTTP 鉴权启用后，API 与所有内部 MQTT 服务必须使用同一组非空凭据。
MQTT_INTERNAL_USERNAME=ingest-service
MQTT_INTERNAL_PASSWORD=change-me

# Kafka（单机 KRaft）
# 主机访问建议用 9094（EXTERNAL listener）
KAFKA_BROKERS=localhost:9094
KAFKA_LOG_RETENTION_HOURS=72
# KRaft Cluster ID：需要是 base64 UUID（可用 `docker run --rm apache/kafka:3.7.0 bash -lc "/opt/kafka/bin/kafka-storage.sh random-uuid"` 生成）
CLUSTER_ID=5L6g3nShT-eMCtK--X86sw

# Kafka UI（可选 profile：ops）
# 为避免与 api-service 默认端口 8080 冲突，默认改为 8081
KAFKA_UI_PORT=8081

# API/登录（docker-compose.app.yml 会用到）
# - AUTH_REQUIRED=false：可关闭登录（仅建议用于内网演示/临时验收）
AUTH_REQUIRED=true
# - 登录加密密钥（开启登录时必须设置强随机值）
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
# - 登录有效期（秒，可选）
JWT_ACCESS_EXPIRES_IN_SECONDS=7200
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# 首次创建管理员账号的临时通行证（可选）
ADMIN_API_TOKEN=

# 是否开启数据库管理接口（不建议长期打开）
DB_ADMIN_ENABLED=false

# 允许访问的前端地址白名单（逗号分隔，可留空）
CORS_ORIGINS=

# HarmonyOS Push Kit（可选；前台 SSE 不依赖这些配置）
HUAWEI_PUSH_ENABLED=false
HUAWEI_PUSH_TOKEN_URL=https://oauth-login.cloud.huawei.com/oauth2/v3/token
# 在 AGC Push Kit 服务端文档/控制台中取得完整发送地址，包含项目标识与 API 版本。
HUAWEI_PUSH_SEND_URL=
HUAWEI_PUSH_CLIENT_ID=
HUAWEI_PUSH_CLIENT_SECRET=

# 通晓现场告警终端（桥接服务继续复用原执行器 URL 配置名，避免破坏 API/桌面端兼容性）
RK3568_ALARM_ACTUATOR_URL=http://tongxiao-alarm-bridge:18088
TONGXIAO_DEVICE_ID=00000000-0000-4000-8000-000000022206
# 完成 SU03-T 上电静音重新生成与断电重启实测前必须保持 false。
TONGXIAO_VOICE_ENABLED=false
TONGXIAO_ALARM_BRIDGE_PORT=18088
TONGXIAO_PRESENCE_STALE_SECONDS=90

# RK3568 边缘侧状态口（可选；配置后系统监控优先读取实时 sidecar，失败再回退本地证据/中心库推导）
RK3568_FIELD_LINK_MONITOR_URL=http://192.168.124.179:18081/v1/summary
RK3568_HERMES_EDGE_SUPERVISOR_URL=http://192.168.124.179:18082/v1/supervision
RK3568_STATUS_HTTP_TIMEOUT_MS=6000

# Optional edge AI sidecar profile (`--profile edge-ai`). It is isolated from
# ingest/rule services and can be stopped without affecting monitoring.
EDGE_MODEL_TRAINING_WINDOW_HOURS=24
EDGE_MODEL_RETRAIN_INTERVAL_MS=21600000
AI_PREDICT_HORIZON_SECONDS=3600
AI_PREDICTION_POSTGRES_POOL_MAX=5
