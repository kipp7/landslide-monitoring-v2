# Production example env file for infra/compose/docker-compose.yml + docker-compose.app.yml
# Copy to `infra/compose/.env` and fill in strong secrets before deployment.

TZ=Asia/Shanghai

# Persisted data directories (recommended to keep outside the repo in production)
DATA_DIR=../../data

# Postgres
PG_USER=landslide
PG_PASSWORD=change-me-please
PG_DATABASE=landslide_monitor
PG_PORT=5432

# ClickHouse
CH_DATABASE=landslide
CH_USER=landslide
CH_PASSWORD=change-me-please

# Redis (if you enable redis usage in workers)
REDIS_PASSWORD=change-me-please

# EMQX dashboard (if you enable MQTT/EMQX)
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=change-me-please
MQTT_INTERNAL_USERNAME=ingest-service
MQTT_INTERNAL_PASSWORD=change-me-please

# API security
AUTH_REQUIRED=true
JWT_ACCESS_SECRET=change-me-please
JWT_REFRESH_SECRET=change-me-please
ADMIN_API_TOKEN=
DB_ADMIN_ENABLED=false

# CORS (comma-separated). Example: https://your-domain.com,https://admin.your-domain.com
CORS_ORIGINS=

# HarmonyOS Push Kit (enable after AGC project, signing, and server credentials are ready)
HUAWEI_PUSH_ENABLED=false
HUAWEI_PUSH_TOKEN_URL=https://oauth-login.cloud.huawei.com/oauth2/v3/token
HUAWEI_PUSH_SEND_URL=
HUAWEI_PUSH_CLIENT_ID=
HUAWEI_PUSH_CLIENT_SECRET=

# Optional: Kafka broker(s) exposed to the API service (comma-separated)
KAFKA_BROKERS=

# Optional: Kafka UI host port (only used when starting compose with profile "ops")
KAFKA_UI_PORT=8081

# RK3568 edge sidecars.
# LAN deployment example:
#   RK3568_ALARM_ACTUATOR_URL=http://192.168.124.179:18087
#   RK3568_FIELD_LINK_MONITOR_URL=http://192.168.124.179:18081/v1/summary
#   RK3568_HERMES_EDGE_SUPERVISOR_URL=http://192.168.124.179:18082/v1/supervision
# Cloud deployment through reverse SSH + docker bridge example:
#   RK3568_ALARM_ACTUATOR_URL=http://172.18.0.1:28087
#   RK3568_FIELD_LINK_MONITOR_URL=http://172.18.0.1:28081/v1/summary
#   RK3568_HERMES_EDGE_SUPERVISOR_URL=http://172.18.0.1:28082/v1/supervision
RK3568_ALARM_ACTUATOR_URL=
RK3568_FIELD_LINK_MONITOR_URL=
RK3568_HERMES_EDGE_SUPERVISOR_URL=
RK3568_STATUS_HTTP_TIMEOUT_MS=6000
