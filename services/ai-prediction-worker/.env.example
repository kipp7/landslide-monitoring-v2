SERVICE_NAME=ai-prediction-worker

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ai-prediction-worker
KAFKA_GROUP_ID=ai-prediction-worker.v1
KAFKA_TOPIC_TELEMETRY_RAW=telemetry.raw.v1
KAFKA_TOPIC_AI_PREDICTIONS=ai.predictions.v1

# Postgres (choose one)
# POSTGRES_URL=postgresql://landslide:landslide@localhost:5432/landslide_monitor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=landslide
POSTGRES_PASSWORD=landslide
POSTGRES_DATABASE=landslide_monitor
POSTGRES_POOL_MAX=5

# ClickHouse（可选；配置后启用通用历史窗口特征 + 1d/3d/7d replay 降雨特征）
# CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=landslide
CLICKHOUSE_TABLE=telemetry_raw

# Model behavior
MODEL_KEY=heuristic.v1
MODEL_VERSION=1
PREDICT_HORIZON_SECONDS=3600
# Example regional replay registry:
# ARTIFACT_ROOT_DIR=artifacts/models/regional-experts/phase1-rainfall-replay
ARTIFACT_ROOT_DIR=artifacts/models
FEATURE_HISTORY_LOOKBACK_HOURS=192
