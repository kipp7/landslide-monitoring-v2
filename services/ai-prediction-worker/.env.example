SERVICE_NAME=ai-prediction-worker

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ai-prediction-worker
KAFKA_GROUP_ID=ai-prediction-worker.v1
KAFKA_TOPIC_TELEMETRY_RAW=telemetry.raw.v1
KAFKA_TOPIC_AI_PREDICTIONS=ai.predictions.v1
# Backward-compatible default is true. Set false for training/model coordination
# without generating one server prediction for every telemetry message.
SERVER_PREDICTIONS_ENABLED=true

# MQTT edge model distribution and prediction return path
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=ingest-service
# MQTT_PASSWORD=
MQTT_CLIENT_ID=ai-prediction-worker
MQTT_EDGE_PREDICTION_TOPIC=edge/ai/predictions/+
MQTT_EDGE_MODEL_TOPIC=edge/ai/models/landslide-risk/v1

# Postgres (choose one)
# POSTGRES_URL=postgresql://landslide:landslide@localhost:5432/landslide_monitor
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=landslide
POSTGRES_PASSWORD=landslide
POSTGRES_DATABASE=landslide_monitor
POSTGRES_POOL_MAX=5

# ClickHouse（可选；配置后启用通用历史窗口特征 + 1d/3d/7d replay 降雨特征）
# CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=landslide
CLICKHOUSE_TABLE=telemetry_raw

# Model behavior
MODEL_KEY=heuristic.v1
MODEL_VERSION=1
PREDICT_HORIZON_SECONDS=3600
# Example regional replay registry:
# ARTIFACT_ROOT_DIR=artifacts/models/regional-experts/phase1-rainfall-replay
ARTIFACT_ROOT_DIR=artifacts/models
FEATURE_HISTORY_LOOKBACK_HOURS=192

# Edge risk model is calibrated from recent ClickHouse history, versioned on disk,
# then published as a retained MQTT message for RK3568 Hermes.
EDGE_MODEL_DIRECTORY=./data/models
EDGE_MODEL_TRAINING_WINDOW_HOURS=24
EDGE_MODEL_RETRAIN_INTERVAL_MS=21600000
