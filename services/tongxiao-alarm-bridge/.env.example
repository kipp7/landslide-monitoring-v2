# tongxiao-alarm-bridge example config (DO NOT COMMIT REAL SECRETS)

SERVICE_NAME=tongxiao-alarm-bridge
ALARM_BRIDGE_HOST=0.0.0.0
ALARM_BRIDGE_PORT=18088

TONGXIAO_DEVICE_ID=00000000-0000-4000-8000-000000022206
TONGXIAO_VOICE_ENABLED=false

MQTT_URL=mqtt://127.0.0.1:1883
# Must match MQTT_INTERNAL_USERNAME/MQTT_INTERNAL_PASSWORD when EMQX auth is enabled.
MQTT_USERNAME=ingest-service
MQTT_PASSWORD=change-me
MQTT_ALARM_DESIRED_PREFIX=alarm/desired/
MQTT_ALARM_REPORTED_PREFIX=alarm/reported/
MQTT_PRESENCE_PREFIX=presence/
# Board online status expires when no presence event is received within this window.
TONGXIAO_PRESENCE_STALE_SECONDS=90
