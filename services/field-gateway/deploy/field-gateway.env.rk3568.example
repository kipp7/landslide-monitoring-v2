SERVICE_NAME=field-gateway
SERIAL_DEVICE=/dev/ttyS3
SERIAL_BAUD_RATE=115200

MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_TELEMETRY_PREFIX=telemetry/
MQTT_TOPIC_COMMAND_PREFIX=cmd/
MQTT_TOPIC_ACK_PREFIX=cmd_ack/
SOUTHBOUND_NODES_JSON=[{"fieldNodeId":"A","deviceId":"00000000-0000-0000-0000-000000000001","installLabel":"FIELD-NODE-A","southboundPort":"/dev/ttyS3","enabled":true}]

SPOOL_ROOT_DIR=/var/lib/lsmv2/field-gateway/spool
HEALTH_FILE_PATH=/var/lib/lsmv2/field-gateway/health/runtime-health.json

MQTT_PUBLISH_TIMEOUT_MS=8000
REPLAY_INTERVAL_MS=5000
HEALTH_EMIT_INTERVAL_MS=5000
MAX_MESSAGE_BYTES=262144
MAX_PENDING_RECORDS=10000
SPOOL_RETENTION_PUBLISHED=200
SPOOL_RETENTION_REJECTED=200
