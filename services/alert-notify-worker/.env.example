# alert-notify-worker example config (DO NOT COMMIT REAL SECRETS)

SERVICE_NAME=alert-notify-worker

KAFKA_BROKERS=127.0.0.1:9094
KAFKA_CLIENT_ID=alert-notify-worker
KAFKA_GROUP_ID=alert-notify-worker.v1
KAFKA_TOPIC_ALERTS_EVENTS=alerts.events.v1

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=landslide
POSTGRES_PASSWORD=
POSTGRES_DATABASE=landslide_monitor
POSTGRES_POOL_MAX=5

# which channel to write notifications for (app/sms/email/wechat)
NOTIFY_TYPE=app

# SMS recipient resolution:
# - subscriptions: use users + user_alert_subscriptions
# - contact_library: use alert_contacts + alert_contact_bindings
# - both: write both existing user notifications and contact-library delivery jobs
SMS_RECIPIENT_MODE=subscriptions

# SMS provider:
# - mock: no external provider, marks jobs sent with a mock provider id
# - aliyun: Alibaba Cloud SMS SDK. Requires sign/template approval and real credentials.
SMS_PROVIDER=mock
SMS_REAL_SEND_ENABLED=false
SMS_ALIYUN_ENDPOINT=dysmsapi.aliyuncs.com
SMS_ALIYUN_ACCESS_KEY_ID=
SMS_ALIYUN_ACCESS_KEY_SECRET=
SMS_ALIYUN_SIGN_NAME=
SMS_ALIYUN_TEMPLATE_CODE=
